function main of none begin

end function

function test0 of u16 a, u16 b returns u16 begin
	variable c is u16;
	variable d is u16;
	variable f is u16;
	
	if a > b then
		c gets a + b;
		d gets a - b;
		f gets a - b;
	else
		d gets a - b;
		f gets a - b;
	end if
	
	c gets (a + b) - f;
	variable e is u16 gets d + (a - b);
	
	while c > d do
		d gets d + (a - b) + c;
	end while
end function
